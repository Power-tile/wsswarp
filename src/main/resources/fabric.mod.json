{
	"schemaVersion": 1,
	"id": "wsswarp",
	"version": "${1.0}",
	"name": "wsswarp",
	"description": "Use WebSocket instead of raw TCP to connect to Minecraft servers.",
	"authors": [
		"Power_tile"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/wsswarp/icon.png",
	"environment": "*",
